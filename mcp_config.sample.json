{
  "filesystem": {
    "command": "node",
    "args": [
      "/usr/local/lib/node_modules/@modelcontextprotocol/server-filesystem/build/index.js",
      "/Users/username/Documents"
    ],
    "enabled": true
  },
  "notes": {
    "command": "node",
    "args": [
      "/path/to/mcp-apple-notes/build/index.js"
    ],
    "enabled": true
  },
  "calendar": {
    "command": "node",
    "args": [
      "/usr/local/lib/node_modules/mcp-ical/index.js"
    ],
    "enabled": false
  }
}
