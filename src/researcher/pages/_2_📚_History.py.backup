"""
History Page for Researcher - Session and group management.

This page provides comprehensive interface for managing sessions and groups,
including viewing, creating, deleting, searching, and filtering sessions
with date range and tag filters. Features calendar visualization for session analytics.
"""

import json
import logging
from datetime import datetime, timedelta
from collections import Counter
from typing import List, Dict, Optional

import streamlit as st
from pages.shared_utils import load_session_helper, initialize_session

LOGGER = logging.getLogger(__name__)


def render_group_management_sidebar():
    """サイドバーにグループ管理UIを表示"""
    with st.sidebar:
        st.title("📁 会話グループ")
        
        # Display current group
        current_group_id = st.session_state.get("current_group_id", 1)
        current_group = st.session_state.session_manager.get_group(current_group_id)
        if current_group:
            st.info(f"現在: {current_group['title']}")
        else:
            st.info("現在: デフォルト")
        
        # Group list
        groups = st.session_state.session_manager.list_groups()
        if groups:
            with st.expander("📂 グループ一覧", expanded=True):
                for group in groups:
                    if st.button(
                        f"📁 {group['title']} ({group['session_count']}件)",
                        key=f"group_{group['id']}",
                        use_container_width=True
                    ):
                        LOGGER.info(f"Switching to group {group['id']}: {group['title']}")
                        st.session_state.current_group_id = group['id']
                        st.rerun()
        
        st.divider()
        
        # New group creation
        with st.expander("➕ 新規グループ作成", expanded=False):
            new_group_title = st.text_input("グループ名", key="new_group_title")
            if st.button("作成", key="create_group_btn"):
                if new_group_title:
                    new_group_id = st.session_state.session_manager.create_group(new_group_title)
                    if new_group_id:
                        st.success(f"グループ '{new_group_title}' を作成しました")
                        st.session_state.current_group_id = new_group_id
                        st.rerun()
                    else:
                        st.error("グループ作成に失敗しました")
                else:
                    st.warning("グループ名を入力してください")
        
        # Group rename
        if current_group_id != 1:  # デフォルトグループは変更不可
            with st.expander("✏️ グループ名変更", expanded=False):
                rename_title = st.text_input("新しいグループ名", key="rename_group_title")
                if st.button("変更", key="rename_group_btn"):
                    if rename_title:
                        success = st.session_state.session_manager.rename_group(current_group_id, rename_title)
                        if success:
                            st.success(f"グループ名を '{rename_title}' に変更しました")
                            st.rerun()
                        else:
                            st.error("グループ名変更に失敗しました")
        
        # Group deletion
        if current_group_id != 1:  # デフォルトグループは削除不可
            with st.expander("🗑️ グループ削除", expanded=False):
                st.warning("⚠️ グループを削除すると、セッションはデフォルトグループに移動されます")
                if st.button("削除を確定", key="delete_group_btn", type="primary"):
                    deleted = st.session_state.session_manager.delete_group(current_group_id, move_to_default=True)
                    if deleted:
                        st.success("グループを削除しました")
                        st.session_state.current_group_id = 1
                        st.rerun()
                    else:
                        st.error("グループ削除に失敗しました")
        
        st.divider()
        st.page_link("pages/1_💬_Chat.py", label="💬 チャットに戻る", icon="💬")


def extract_unique_tags(sessions: List[Dict]) -> List[str]:
    """セッション一覧からユニークなタグを抽出"""
    all_tags = []
    for session in sessions:
        tags_json = session.get("tags")
        if tags_json:
            try:
                tags = json.loads(tags_json) if isinstance(tags_json, str) else tags_json
                if isinstance(tags, list):
                    all_tags.extend(tags)
            except (json.JSONDecodeError, TypeError):
                continue
    return sorted(list(set(all_tags)))


def render_search_section():
    """セッション検索UIを表示"""
    st.subheader("🔍 セッション検索")
    
    search_query = st.text_input(
        "キーワードで検索（名前、履歴、タグ）",
        key="session_search",
        placeholder="例: AI, Python, 機械学習..."
    )
    
    if search_query:
        try:
            results = st.session_state.session_manager.search_sessions(search_query)
            if results:
                st.write(f"**{len(results)}件** の検索結果")
                for session in results[:10]:  # 最大10件表示
                    col1, col2 = st.columns([3, 1])
                    with col1:
                        # Display tags if available
                        tags_display = ""
                        if session.get("tags"):
                            try:
                                tags = json.loads(session["tags"]) if isinstance(session["tags"], str) else session["tags"]
                                if tags:
                                    tags_display = " | ".join([f"🏷️ {tag}" for tag in tags])
                            except:
                                pass
                        
                        button_label = f"📄 {session['name']}"
                        if tags_display:
                            button_label += f"\n{tags_display}"
                        
                        if st.button(button_label, key=f"search_{session['id']}", use_container_width=True):
                            st.session_state.load_session_id = session['id']
                            st.session_state.load_session_name = session['name']
                            st.switch_page("pages/1_💬_Chat.py")
                    
                    with col2:
                        st.caption(f"更新: {session['updated_at'][:10]}")
            else:
                st.info("検索結果がありません")
        except Exception as e:
            LOGGER.error(f"Search failed: {e}")
            st.error(f"検索に失敗しました: {e}")


def render_date_filter_section():
    """日付フィルタUIを表示"""
    st.subheader("📅 日付フィルタ")
    
    col1, col2 = st.columns(2)
    with col1:
        date_from = st.date_input("開始日", key="date_from", value=None)
    with col2:
        date_to = st.date_input("終了日", key="date_to", value=None)
    
    # Convert to ISO format if selected
    date_from_str = date_from.isoformat() if date_from else None
    date_to_str = date_to.isoformat() if date_to else None
    
    return date_from_str, date_to_str


def render_calendar_visualization(sessions: List[Dict]):
    """カレンダー可視化（日付ごとのセッション数をMarkdownテーブルで表示）"""
    if not sessions:
        return
    
    st.subheader("📊 セッション作成カレンダー")
    
    # 日付ごとのセッション数を集計
    date_counts = Counter()
    for session in sessions:
        created_at = session.get("created_at", "")
        if created_at:
            date = created_at[:10]  # YYYY-MM-DD形式
            date_counts[date] += 1
    
    if not date_counts:
        st.info("セッションデータがありません")
        return
    
    # 最近30日分を表示
    sorted_dates = sorted(date_counts.keys(), reverse=True)[:30]
    
    # Markdownテーブルで表示
    st.markdown("| 日付 | セッション数 | バー |")
    st.markdown("|------|------------|------|")
    max_count = max(date_counts.values())
    for date in sorted_dates:
        count = date_counts[date]
        bar = "█" * int((count / max_count) * 20)  # 最大20文字のバー
        st.markdown(f"| {date} | {count}件 | {bar} |")


def render_tag_filter_section(current_group_id: int) -> Optional[List[str]]:
    """タグフィルタUIを表示"""
    st.subheader("🏷️ タグフィルタ")
    
    try:
        # 現在のグループの全セッションからタグを抽出
        all_sessions = st.session_state.session_manager.list_sessions(group_id=current_group_id)
        unique_tags = extract_unique_tags(all_sessions)
        
        if unique_tags:
            selected_tags = st.multiselect(
                "タグを選択してフィルタリング",
                options=unique_tags,
                key="tag_filter",
                help="複数選択でAND条件（すべてのタグを含むセッションのみ表示）"
            )
            return selected_tags if selected_tags else None
        else:
            st.info("タグが設定されているセッションがありません")
            return None
    except Exception as e:
        LOGGER.error(f"Tag filter error: {e}")
        st.error(f"タグフィルタの取得に失敗しました: {e}")
        return None


def render_session_list(sessions: List[Dict]):
    """セッション一覧を表示"""
    st.subheader("📋 最近のセッション")
    
    if not sessions:
        st.info("セッションがありません")
        return
    
    st.write(f"**{len(sessions)}件** のセッション（最大10件表示）")
    
    for session in sessions[:10]:
        # Parse tags
        tags_list = []
        if session.get("tags"):
            try:
                tags_list = json.loads(session["tags"]) if isinstance(session["tags"], str) else session["tags"]
            except:
                pass
        
        # Create button with session info
        col1, col2 = st.columns([3, 1])
        with col1:
            button_label = f"📄 {session['name']}"
            if st.button(button_label, key=f"session_{session['id']}", use_container_width=True):
                st.session_state.load_session_id = session['id']
                st.session_state.load_session_name = session['name']
                st.switch_page("pages/1_💬_Chat.py")
            
            # Display tags as badges
            if tags_list:
                tags_html = " ".join([
                    f'<span style="background-color: #e0e0e0; padding: 2px 8px; border-radius: 4px; margin-right: 4px; font-size: 0.85em;">🏷️ {tag}</span>'
                    for tag in tags_list
                ])
                st.markdown(tags_html, unsafe_allow_html=True)
        
        with col2:
            st.caption(f"作成: {session['created_at'][:10]}")
            st.caption(f"更新: {session['updated_at'][:10]}")
        
        st.divider()


def get_all_sessions_for_selection() -> List[Dict]:
    """全グループの全セッションを取得し、selectbox用のオプションリストを生成"""
    try:
        # Get all sessions without group filter
        all_sessions = st.session_state.session_manager.list_sessions()
        
        # Get all groups for group name mapping
        groups = st.session_state.session_manager.list_groups()
        group_map = {group['id']: group['title'] for group in groups}
        
        # Build selection options
        selection_options = []
        for session in all_sessions:
            group_id = session.get('group_id', 1)
            group_name = group_map.get(group_id, "デフォルト")
            label = f"[{group_name}] {session['name']} (ID: {session['id']})"
            selection_options.append({
                "label": label,
                "session_id": session['id'],
                "session_name": session['name']
            })
        
        return selection_options
    except Exception as e:
        LOGGER.error(f"Failed to get sessions for selection: {e}")
        return []


def format_search_results_table(search_results: List[Dict]) -> Optional[List[Dict]]:
    """検索結果をテーブル形式に変換"""
    if not search_results:
        return None
    
    formatted_results = []
    for result in search_results:
        formatted_results.append({
            "タイトル": result.get("title", "N/A"),
            "URL": result.get("url", "N/A"),
            "スニペット": result.get("snippet", "")[:100] + "..." if len(result.get("snippet", "")) > 100 else result.get("snippet", ""),
            "日付": result.get("date", "N/A"),
            "スコア": result.get("score", "N/A")
        })
    
    return formatted_results


def render_session_detail_readonly(session_id: int):
    """セッション詳細をread-onlyで表示"""
    try:
        # Load session data
        session_data = st.session_state.session_manager.load_session(session_id)
        
        if not session_data:
            st.error("セッションが見つかりません")
            return
        
        # Extract session components with fallbacks
        history = session_data.get("history", [])
        search_results = session_data.get("search_results", [])
        last_evaluation_score = session_data.get("last_evaluation_score")
        tags = session_data.get("tags", [])
        
        # Session header information
        st.subheader(f"📄 {session_data.get('name', 'Untitled Session')}")
        
        col1, col2, col3, col4 = st.columns(4)
        with col1:
            st.metric("作成日時", session_data.get('created_at', 'N/A')[:16])
        with col2:
            st.metric("更新日時", session_data.get('updated_at', 'N/A')[:16])
        with col3:
            st.metric("モデル", session_data.get('model', 'N/A'))
        with col4:
            st.metric("言語", session_data.get('language', 'ja'))
        
        # Display tags
        if tags:
            tags_html = " ".join([
                f'<span style="background-color: #e0e0e0; padding: 4px 12px; border-radius: 6px; margin-right: 6px; font-size: 0.9em;">🏷️ {tag}</span>'
                for tag in tags
            ])
            st.markdown("**タグ:**")
            st.markdown(tags_html, unsafe_allow_html=True)
        
        st.divider()
        
        # Display conversation history
        st.subheader("💬 会話履歴")
        if history:
            for msg in history:
                role = msg.get("role", "")
                content = msg.get("content", "")
                
                # Skip system messages
                if role == "system":
                    continue
                
                # Display user and assistant messages
                if role in ["user", "assistant"]:
                    with st.chat_message(role):
                        st.markdown(content)
        else:
            st.info("会話履歴がありません")
        
        st.divider()
        
        # Display search results
        if search_results:
            with st.expander("🔍 検索結果", expanded=False):
                # Format search results as table
                table_data = format_search_results_table(search_results)
                
                if table_data:
                    # Create clickable links for URLs using markdown in dataframe
                    import pandas as pd
                    df = pd.DataFrame(table_data)
                    
                    # Convert URL column to clickable markdown links
                    def make_clickable(url):
                        if url and url != "N/A":
                            return f'<a href="{url}" target="_blank">{url}</a>'
                        return url
                    
                    if "URL" in df.columns:
                        df["URL"] = df["URL"].apply(make_clickable)
                    
                    # Display as HTML table with clickable links
                    st.markdown(df.to_html(escape=False, index=False), unsafe_allow_html=True)
                else:
                    st.info("検索結果がありません")
        
        # Display evaluation score
        if last_evaluation_score:
            with st.expander("📊 品質評価", expanded=False):
                # Handle different evaluation score structures
                if isinstance(last_evaluation_score, dict):
                    # Display metrics in columns
                    metric_keys = [k for k in last_evaluation_score.keys() if k != 'comment']
                    if metric_keys:
                        cols = st.columns(len(metric_keys))
                        for idx, key in enumerate(metric_keys):
                            with cols[idx]:
                                value = last_evaluation_score[key]
                                # Format value appropriately
                                if isinstance(value, (int, float)):
                                    st.metric(key, f"{value:.2f}" if isinstance(value, float) else value)
                                else:
                                    st.metric(key, str(value))
                    
                    # Display comment if available
                    if 'comment' in last_evaluation_score:
                        st.markdown("**コメント:**")
                        st.info(last_evaluation_score['comment'])
                else:
                    st.write(last_evaluation_score)
        
        st.divider()
        
        # Edit button
        if st.button("✏️ このセッションを編集", key="edit_session_btn", type="primary"):
            LOGGER.info(f"Switching to edit mode for session {session_id}")
            st.session_state.load_session_id = session_id
            st.session_state.load_session_name = session_data.get("name", "")
            st.switch_page("pages/1_💬_Chat.py")
    
    except json.JSONDecodeError as e:
        LOGGER.error(f"Failed to parse session {session_id}: {e}")
        st.warning("古いセッション形式です。データの解析に失敗しました。")
    except Exception as e:
        LOGGER.error(f"Failed to load session {session_id}: {e}")
        st.error(f"セッションの読み込みに失敗しました: {e}")


def main():
    """History page main entry point."""
    st.set_page_config(
        page_title="History - Researcher",
        page_icon="📚",
        layout="wide",
        initial_sidebar_state="expanded"
    )
    
    # Initialize session if not already done (idempotent, safe for deep-links)
    initialize_session()
    
    st.title("📚 履歴管理")
    st.markdown("*セッションとグループの管理*")
    st.markdown("---")
    
    # Sidebar: Group management
    render_group_management_sidebar()
    
    # Get current group
    current_group_id = st.session_state.get("current_group_id", 1)
    
    # Main content layout
    tab1, tab2, tab3, tab4 = st.tabs(["🔍 検索", "📅 日付フィルタ", "🏷️ タグフィルタ", "📖 セッション詳細"])
    
    with tab1:
        render_search_section()
    
    with tab2:
        date_from, date_to = render_date_filter_section()
        
        # Fetch sessions with date filter
        try:
            filtered_sessions = st.session_state.session_manager.list_sessions(
                group_id=current_group_id,
                date_from=date_from,
                date_to=date_to
            )
            
            # Calendar visualization
            if date_from or date_to:
                render_calendar_visualization(filtered_sessions)
                st.divider()
            
            # Display filtered sessions
            render_session_list(filtered_sessions)
        except Exception as e:
            LOGGER.error(f"Date filter error: {e}")
            st.error(f"日付フィルタの適用に失敗しました: {e}")
    
    with tab3:
        selected_tags = render_tag_filter_section(current_group_id)
        
        # Fetch sessions with tag filter
        try:
            filtered_sessions = st.session_state.session_manager.list_sessions(
                group_id=current_group_id,
                tags=selected_tags
            )
            
            # Display filtered sessions
            render_session_list(filtered_sessions)
        except Exception as e:
            LOGGER.error(f"Tag filter error: {e}")
            st.error(f"タグフィルタの適用に失敗しました: {e}")
    
    with tab4:
        st.subheader("📖 セッション詳細閲覧")
        st.markdown("*過去のセッションを閲覧できます。編集する場合は「編集」ボタンをクリックしてください。*")
        st.divider()
        
        # Get all sessions for selection
        session_options = get_all_sessions_for_selection()
        
        if session_options:
            # Create selectbox options
            option_labels = [opt["label"] for opt in session_options]
            option_map = {opt["label"]: opt for opt in session_options}
            
            selected_label = st.selectbox(
                "セッションを選択",
                options=option_labels,
                key="selected_session_label",
                help="全グループの全セッションから選択できます"
            )
            
            if selected_label:
                selected_option = option_map[selected_label]
                selected_session_id = selected_option["session_id"]
                
                # Store in session state for persistence
                st.session_state.selected_session_id = selected_session_id
                
                LOGGER.info(f"Selected session {selected_session_id} for read-only view")
                
                st.divider()
                
                # Render session detail in read-only mode
                render_session_detail_readonly(selected_session_id)
        else:
            st.info("セッションがありません")


if __name__ == "__main__":
    main()
