def test_session_manager_warns_on_outdated_schema(temp_db_path, caplog):
    """SessionManagerが古いスキーマで警告を出すか"""
    import logging
    
    # 基本的なsessionsテーブルのみ作成（schema_versionなし）
    with sqlite3.connect(temp_db_path) as conn:
        conn.execute("""
            CREATE TABLE IF NOT EXISTS sessions (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL,
                history TEXT NOT NULL,
                model TEXT NOT NULL,
                language TEXT NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        conn.commit()
    
    # SessionManagerを初期化
    with caplog.at_level(logging.WARNING):
        manager = SessionManager(db_path=temp_db_path)
    
    # 警告メッセージが出力されているか確認
    assert any("Schema version table not found" in record.message for record in caplog.records)


def test_migration_preserves_existing_data(temp_db_path):
    """マイグレーションが既存データを保持するか"""
    import sys
    from pathlib import Path
    
    project_root = Path(__file__).parent.parent
    sys.path.insert(0, str(project_root))
    
    from migrate_db import run_migrations
    
    # 古いスキーマでデータを作成
    with sqlite3.connect(temp_db_path) as conn:
        conn.execute("""
            CREATE TABLE IF NOT EXISTS sessions (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL,
                history TEXT NOT NULL,
                model TEXT NOT NULL,
                language TEXT NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        conn.execute(
            "INSERT INTO sessions (name, history, model, language) VALUES (?, ?, ?, ?)",
            ("Old Session", "[]", "gpt-oss:20b", "ja")
        )
        conn.commit()
        session_id = conn.execute("SELECT last_insert_rowid()").fetchone()[0]
    
    # マイグレーション実行
    success = run_migrations(temp_db_path)
    assert success is True
    
    # データが保持されているか確認
    manager = SessionManager(db_path=temp_db_path)
    loaded = manager.load_session(session_id)
    assert loaded is not None
    assert loaded["name"] == "Old Session"
    assert loaded["group_id"] == 1  # デフォルトグループに割り当てられている

