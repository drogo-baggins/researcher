def test_save_and_load_evaluation_score(session_manager):
    """Test saving and loading session with evaluation score."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    # Sample evaluation score
    eval_score = {
        "accuracy_score": 0.85,
        "freshness_score": 0.90,
        "overall_score": 0.875,
        "reasoning": "Good response with recent information"
    }
    
    # Save with evaluation score
    saved = session_manager.save_session(
        session_id, [], "gpt-oss:20b", "ja", last_evaluation_score=eval_score
    )
    assert saved is True
    
    # Load and verify
    loaded = session_manager.load_session(session_id)
    assert loaded["last_evaluation_score"] == eval_score
    assert loaded["last_evaluation_score"]["overall_score"] == 0.875


def test_save_session_without_evaluation_score(session_manager):
    """Test saving session without evaluation score (backward compatibility)."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    # Save without evaluation score
    saved = session_manager.save_session(session_id, [], "gpt-oss:20b", "ja")
    assert saved is True
    
    # Load and verify (None is expected)
    loaded = session_manager.load_session(session_id)
    assert loaded["last_evaluation_score"] is None


def test_save_and_load_evaluation_score_with_history(session_manager):
    """Test saving and loading both history and evaluation score together."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    history = [
        {"role": "user", "content": "What is AI?"},
        {"role": "assistant", "content": "AI is artificial intelligence..."}
    ]
    
    eval_score = {
        "accuracy_score": 0.92,
        "freshness_score": 0.88,
        "overall_score": 0.90
    }
    
    # Save both history and evaluation score
    saved = session_manager.save_session(
        session_id, history, "gpt-oss:20b", "ja", last_evaluation_score=eval_score
    )
    assert saved is True
    
    # Load and verify both are preserved
    loaded = session_manager.load_session(session_id)
    assert loaded["history"] == history
    assert loaded["last_evaluation_score"] == eval_score


def test_rename_session_with_long_name(session_manager):
    """Test renaming session with name longer than 50 characters."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    # Create a long name (over 50 chars)
    long_name = "Session " + "x" * 60
    
    # Rename (no truncation at rename_session level)
    renamed = session_manager.rename_session(session_id, long_name)
    assert renamed is True
    
    # Verify full name is stored
    loaded = session_manager.load_session(session_id)
    assert loaded["name"] == long_name
    assert len(loaded["name"]) > 50


def test_message_with_embedded_evaluation(session_manager):
    """Test saving and loading session with embedded evaluation scores in messages."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    # History with embedded evaluation in message
    history = [
        {"role": "user", "content": "What is Python?"},
        {
            "role": "assistant",
            "content": "Python is a programming language...",
            "evaluation": {
                "accuracy_score": 0.88,
                "freshness_score": 0.85,
                "overall_score": 0.87,
                "reasoning": "Accurate but could mention more recent features"
            }
        }
    ]
    
    # Save with embedded evaluations
    saved = session_manager.save_session(
        session_id, history, "gpt-oss:20b", "ja"
    )
    assert saved is True
    
    # Load and verify embedded evaluation is preserved
    loaded = session_manager.load_session(session_id)
    assert len(loaded["history"]) == 2
    assert "evaluation" in loaded["history"][1]
    assert loaded["history"][1]["evaluation"]["accuracy_score"] == 0.88


# ========================================
# Group Management Tests
# ========================================

def test_create_group_success(session_manager):
    """Test successful group creation."""
    group_id = session_manager.create_group("Research Project")
    
    assert group_id is not None
    assert isinstance(group_id, int)
    
    # Verify group exists
    group = session_manager.get_group(group_id)
    assert group is not None
    assert group["title"] == "Research Project"
    assert group["session_count"] == 0


def test_list_groups_ordered_by_updated_at(session_manager):
    """Test listing groups ordered by most recently updated."""
    # Create three groups
    group1_id = session_manager.create_group("Group 1")
    group2_id = session_manager.create_group("Group 2")
    group3_id = session_manager.create_group("Group 3")
    
    # Update group1 to make it more recent
    import time
    time.sleep(0.1)
    session_manager.update_group_timestamp(group1_id)
    
    # List groups
    groups = session_manager.list_groups()
    
    # Verify order: group1 should be first (most recently updated)
    # Note: Default group (id=1) will also be present
    assert any(g["id"] == group1_id for g in groups)
    # Find group1's position
    group1_pos = next(i for i, g in enumerate(groups) if g["id"] == group1_id)
    # It should be near the top (0 or 1, since default group may be first if recently updated)
    assert group1_pos <= 1


def test_get_group_by_id(session_manager):
    """Test retrieving group by ID."""
    group_id = session_manager.create_group("Test Group")
    
    group = session_manager.get_group(group_id)
    
    assert group is not None
    assert group["id"] == group_id
    assert group["title"] == "Test Group"
    assert "created_at" in group
    assert "updated_at" in group


def test_delete_group_with_session_move(session_manager):
    """Test deleting group and moving sessions to default group."""
    # Create group and session
    group_id = session_manager.create_group("To Delete")
    session_id = session_manager.create_session("Test Session", "gpt-oss:20b", "ja", group_id=group_id)
    
    # Verify session is in the group
    session = session_manager.load_session(session_id)
    assert session["group_id"] == group_id
    
    # Delete group (move_to_default=True)
    deleted = session_manager.delete_group(group_id, move_to_default=True)
    assert deleted is True
    
    # Verify group is deleted
    group = session_manager.get_group(group_id)
    assert group is None
    
    # Verify session moved to default group (id=1)
    session = session_manager.load_session(session_id)
    assert session["group_id"] == 1


def test_delete_group_with_session_deletion(session_manager):
    """Test deleting group and all its sessions."""
    # Create group and session
    group_id = session_manager.create_group("To Delete")
    session_id = session_manager.create_session("Test Session", "gpt-oss:20b", "ja", group_id=group_id)
    
    # Delete group (move_to_default=False)
    deleted = session_manager.delete_group(group_id, move_to_default=False)
    assert deleted is True
    
    # Verify group is deleted
    group = session_manager.get_group(group_id)
    assert group is None
    
    # Verify session is also deleted
    session = session_manager.load_session(session_id)
    assert session is None


def test_delete_default_group_fails(session_manager):
    """Test that deleting default group (id=1) is prevented."""
    # Attempt to delete default group
    deleted = session_manager.delete_group(1)
    
    # Should fail or return False
    assert deleted is False or deleted is None
    
    # Verify default group still exists
    default_group = session_manager.get_group(1)
    assert default_group is not None


def test_rename_group(session_manager):
    """Test renaming a group."""
    group_id = session_manager.create_group("Old Title")
    
    # Rename group
    renamed = session_manager.rename_group(group_id, "New Title")
    assert renamed is True
    
    # Verify new title
    group = session_manager.get_group(group_id)
    assert group["title"] == "New Title"


def test_update_group_timestamp(session_manager):
    """Test updating group timestamp."""
    group_id = session_manager.create_group("Test Group")
    
    # Get initial timestamp
    group1 = session_manager.get_group(group_id)
    timestamp1 = group1["updated_at"]
    
    # Wait and update
    import time
    time.sleep(0.1)
    session_manager.update_group_timestamp(group_id)
    
    # Verify timestamp updated
    group2 = session_manager.get_group(group_id)
    timestamp2 = group2["updated_at"]
    
    assert timestamp2 >= timestamp1


def test_create_session_with_group_id(session_manager):
    """Test creating session with specific group_id."""
    group_id = session_manager.create_group("Project Alpha")
    session_id = session_manager.create_session("Session 1", "gpt-oss:20b", "ja", group_id=group_id)
    
    # Verify session has correct group_id
    session = session_manager.load_session(session_id)
    assert session["group_id"] == group_id


def test_list_sessions_filtered_by_group(session_manager):
    """Test listing sessions filtered by group_id."""
    # Create two groups and sessions
    group1_id = session_manager.create_group("Group 1")
    group2_id = session_manager.create_group("Group 2")
    
    session1_id = session_manager.create_session("Session 1", "gpt-oss:20b", "ja", group_id=group1_id)
    session2_id = session_manager.create_session("Session 2", "gpt-oss:20b", "ja", group_id=group2_id)
    session3_id = session_manager.create_session("Session 3", "gpt-oss:20b", "ja", group_id=group1_id)
    
    # List sessions for group1
    sessions = session_manager.list_sessions(group_id=group1_id)
    
    # Should only have 2 sessions from group1
    assert len(sessions) == 2
    assert all(s["id"] in [session1_id, session3_id] for s in sessions)


def test_session_update_triggers_group_timestamp_update(session_manager):
    """Test that updating session updates its group timestamp."""
    group_id = session_manager.create_group("Test Group")
    session_id = session_manager.create_session("Test Session", "gpt-oss:20b", "ja", group_id=group_id)
    
    # Get initial group timestamp
    group1 = session_manager.get_group(group_id)
    timestamp1 = group1["updated_at"]
    
    # Wait and update session
    import time
    time.sleep(0.1)
    session_manager.save_session(session_id, [{"role": "user", "content": "test"}], "gpt-oss:20b", "ja")
    
    # Verify group timestamp updated
    group2 = session_manager.get_group(group_id)
    timestamp2 = group2["updated_at"]
    
    assert timestamp2 >= timestamp1


