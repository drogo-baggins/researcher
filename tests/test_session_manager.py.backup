def test_load_session_with_missing_search_results_column(temp_db_path):
    """Test loading session from database without search_results column (backward compatibility)."""
    # Create database without search_results column
    conn = sqlite3.connect(temp_db_path)
    cursor = conn.cursor()
    
    # Create old schema (without search_results and group_id)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS sessions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            model TEXT NOT NULL,
            language TEXT DEFAULT 'ja',
            history TEXT DEFAULT '[]',
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            last_evaluation_score TEXT
        )
    """)
    
    # Insert test session
    cursor.execute("""
        INSERT INTO sessions (name, model, language, history)
        VALUES (?, ?, ?, ?)
    """, ("Test Session", "gpt-oss:20b", "ja", json.dumps([{"role": "user", "content": "test"}])))
    
    session_id = cursor.lastrowid
    conn.commit()
    conn.close()
    
    # Create SessionManager (should trigger migration)
    manager = SessionManager(db_path=temp_db_path)
    
    # Load session
    loaded = manager.load_session(session_id)
    
    # Should return empty list as default
    assert loaded is not None
    assert loaded["search_results"] == []


# ========================================
# Database Migration Tests
# ========================================

def test_migration_adds_group_id_column(temp_db_path):
    """Test migration adds group_id column to existing database."""
    # Create old schema without group_id
    conn = sqlite3.connect(temp_db_path)
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS sessions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            model TEXT NOT NULL,
            language TEXT DEFAULT 'ja',
            history TEXT DEFAULT '[]',
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
        )
    """)
    conn.commit()
    conn.close()
    
    # Initialize SessionManager (triggers migration)
    manager = SessionManager(db_path=temp_db_path)
    
    # Verify group_id column exists
    conn = sqlite3.connect(temp_db_path)
    cursor = conn.cursor()
    cursor.execute("PRAGMA table_info(sessions)")
    columns = [col[1] for col in cursor.fetchall()]
    conn.close()
    
    assert "group_id" in columns


