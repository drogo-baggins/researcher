def test_list_sessions_with_tag_filter_single(session_manager):
    """Test filtering sessions by single tag."""
    id1 = session_manager.create_session("S1", tags=["AI", "Python"])
    id2 = session_manager.create_session("S2", tags=["Web"])
    id3 = session_manager.create_session("S3", tags=["AI", "ML"])
    
    # Filter by single tag
    sessions = session_manager.list_sessions(tags=["AI"])
    
    assert len(sessions) == 2
    assert set(s["id"] for s in sessions) == {id1, id3}


def test_list_sessions_with_tag_filter_multiple_and_logic(session_manager):
    """Test filtering sessions by multiple tags (AND logic)."""
    id1 = session_manager.create_session("S1", tags=["AI", "Python"])
    id2 = session_manager.create_session("S2", tags=["AI", "ML"])
    id3 = session_manager.create_session("S3", tags=["Python", "Web"])
    
    # Filter by multiple tags (AND)
    sessions = session_manager.list_sessions(tags=["AI", "Python"])
    
    assert len(sessions) == 1
    assert sessions[0]["id"] == id1


def test_list_sessions_with_date_range_filter(session_manager):
    """Test filtering sessions by date range."""
    # Create sessions with manual dates
    id1 = session_manager.create_session("S1")
    id2 = session_manager.create_session("S2")
    id3 = session_manager.create_session("S3")
    
    # Update created_at manually
    with sqlite3.connect(session_manager.db_path) as conn:
        conn.execute("PRAGMA foreign_keys = ON")
        conn.execute("UPDATE sessions SET created_at = ? WHERE id = ?", ("2025-01-15", id1))
        conn.execute("UPDATE sessions SET created_at = ? WHERE id = ?", ("2025-02-20", id2))
        conn.execute("UPDATE sessions SET created_at = ? WHERE id = ?", ("2025-03-10", id3))
        conn.commit()
    
    # Filter by date range
    sessions = session_manager.list_sessions(date_from="2025-02-01", date_to="2025-02-28")
    
    assert len(sessions) == 1
    assert sessions[0]["id"] == id2


def test_list_sessions_returns_exchange_count(session_manager):
    """Test that list_sessions returns exchange_count field."""
    id1 = session_manager.create_session("S1")
    id2 = session_manager.create_session("S2")
    
    # Add exchanges
    session_manager.save_exchange(id1, "Q1", "A1", "gpt-oss:20b", "ja")
    session_manager.save_exchange(id1, "Q2", "A2", "gpt-oss:20b", "ja")
    session_manager.save_exchange(id2, "Q1", "A1", "gpt-oss:20b", "ja")
    
    # List sessions
    sessions = session_manager.list_sessions()
    
    session1 = next(s for s in sessions if s["id"] == id1)
    session2 = next(s for s in sessions if s["id"] == id2)
    
    assert session1["exchange_count"] == 2
    assert session2["exchange_count"] == 1


def test_list_sessions_with_limit_and_offset(session_manager):
    """Test pagination with limit and offset."""
    # Create 5 sessions
    for i in range(5):
        session_manager.create_session(f"Session {i}")
    
    # Get first 2
    page1 = session_manager.list_sessions(limit=2, offset=0)
    assert len(page1) == 2
    
    # Get next 2
    page2 = session_manager.list_sessions(limit=2, offset=2)
    assert len(page2) == 2
    
    # IDs should not overlap
    page1_ids = {s["id"] for s in page1}
    page2_ids = {s["id"] for s in page2}
    assert len(page1_ids & page2_ids) == 0


