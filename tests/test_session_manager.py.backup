def test_search_results_with_complex_structure(session_manager):
    """Test saving search_results with all possible fields."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    complex_results = [
        {
            "title": "Full Result",
            "url": "https://example.com/full",
            "snippet": "Complete example with all fields",
            "date": "2024-03-10T10:30:00",
            "citation_id": 5,
            "relevance_score": 0.95,
            "credibility_score": 0.88,
            "extra_field": "Should be preserved"
        }
    ]
    
    # Save complex structure
    session_manager.save_session(
        session_id, [], "gpt-oss:20b", "ja", search_results=complex_results
    )
    
