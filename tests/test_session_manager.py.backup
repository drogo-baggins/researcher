    assert session["group_id"] == 1


# ========================================
# search_results Persistence Tests
# ========================================

def test_save_and_load_search_results(session_manager):
    """Test saving and loading search_results."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    search_results = [
        {
            "title": "Python Tutorial",
            "url": "https://example.com/python",
            "snippet": "Learn Python programming",
            "date": "2024-01-15",
            "citation_id": 1,
            "relevance_score": 0.9,
            "credibility_score": 0.85
        },
        {
            "title": "Advanced Python",
            "url": "https://example.com/advanced",
            "snippet": "Advanced topics",
            "date": "2024-02-20",
            "citation_id": 2,
            "relevance_score": 0.8,
            "credibility_score": 0.9
        }
    ]
    
    # Save with search_results
    saved = session_manager.save_session(
        session_id, [], "gpt-oss:20b", "ja", search_results=search_results
    )
    assert saved is True
    
    # Load and verify
    loaded = session_manager.load_session(session_id)
    assert loaded["search_results"] == search_results
    assert len(loaded["search_results"]) == 2
    assert loaded["search_results"][0]["relevance_score"] == 0.9


def test_save_session_without_search_results_preserves_existing(session_manager):
    """Test that saving without search_results parameter preserves existing search_results."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    initial_search_results = [
        {"title": "Initial Result", "url": "https://example.com", "snippet": "Test"}
    ]
    
    # First save with search_results
    session_manager.save_session(
        session_id, [], "gpt-oss:20b", "ja", search_results=initial_search_results
    )
    
    # Second save without search_results parameter
    session_manager.save_session(
        session_id, [{"role": "user", "content": "New message"}], "gpt-oss:20b", "ja"
    )
    
    # Verify search_results are preserved
    loaded = session_manager.load_session(session_id)
    assert loaded["search_results"] == initial_search_results


def test_save_empty_search_results(session_manager):
    """Test saving empty search_results list."""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
