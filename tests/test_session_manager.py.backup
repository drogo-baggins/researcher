def test_migration_assigns_null_group_id_to_default(temp_db_path):
    """Test migration assigns existing sessions with NULL group_id to default group."""
    # Create old schema and insert session without group_id
    conn = sqlite3.connect(temp_db_path)
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS sessions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            model TEXT NOT NULL,
            language TEXT DEFAULT 'ja',
            history TEXT DEFAULT '[]',
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
        )
    """)
    cursor.execute("""
        INSERT INTO sessions (name, model, language, history)
        VALUES (?, ?, ?, ?)
    """, ("Old Session", "gpt-oss:20b", "ja", "[]"))
    session_id = cursor.lastrowid
    conn.commit()
    conn.close()
    
    # Initialize SessionManager (triggers migration)
    manager = SessionManager(db_path=temp_db_path)
    
    # Verify session has group_id = 1
    session = manager.load_session(session_id)
    assert session["group_id"] == 1


def test_migration_idempotent(temp_db_path):
    """Test that running migration multiple times is safe (idempotent)."""
    # First initialization
    manager1 = SessionManager(db_path=temp_db_path)
    group_id = manager1.create_group("Test Group")
    session_id = manager1.create_session("Test Session", "gpt-oss:20b", "ja", group_id=group_id)
    
    # Second initialization (re-run migration)
    manager2 = SessionManager(db_path=temp_db_path)
    
    # Verify data is preserved
    group = manager2.get_group(group_id)
    session = manager2.load_session(session_id)
    
    assert group is not None
    assert group["title"] == "Test Group"
    assert session is not None
    assert session["name"] == "Test Session"
    assert session["group_id"] == group_id


def test_list_sessions_with_group_id_filter_returns_correct_sessions(session_manager):
    """group_idフィルタが正しく動作することを確認"""
    group1_id = session_manager.create_group("Group 1")
    group2_id = session_manager.create_group("Group 2")
    
    session1_id = session_manager.create_session("Session 1", "gpt-oss:20b", "ja", group_id=group1_id)
    session2_id = session_manager.create_session("Session 2", "gpt-oss:20b", "ja", group_id=group2_id)
    session3_id = session_manager.create_session("Session 3", "gpt-oss:20b", "ja", group_id=group1_id)
    
    # Group 1のセッションのみ取得
    sessions = session_manager.list_sessions(group_id=group1_id)
    
    assert len(sessions) == 2
    assert all(s["group_id"] == group1_id for s in sessions)
    assert set(s["id"] for s in sessions) == {session1_id, session3_id}


