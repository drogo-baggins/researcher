# ============================================================================

def test_tags_column_migration(temp_db_path):
    """tags列が正しく追加されることを確認"""
    # SessionManagerの初期化でマイグレーションが実行される
    manager = SessionManager(db_path=temp_db_path)
    
    # データベースに直接接続してカラムを確認
    with sqlite3.connect(temp_db_path) as conn:
        cursor = conn.execute("PRAGMA table_info(sessions)")
        columns = [row[1] for row in cursor.fetchall()]
        assert "tags" in columns, "tags column should exist after migration"


def test_save_session_with_auto_tag(session_manager):
    """auto_tag=Trueでタグが自動生成・保存されることを確認"""
    from unittest.mock import MagicMock
    
    # モックAgentを作成
    mock_agent = MagicMock()
    mock_agent.generate_tags.return_value = ["AI", "検索", "技術"]
    
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    history = [
        {"role": "user", "content": "AIについて教えて"},
        {"role": "assistant", "content": "AIは人工知能のことです"}
    ]
    
    # auto_tag=Trueでセッション保存
    result = session_manager.save_session(
        session_id, history, "gpt-oss:20b", "ja",
        auto_tag=True, agent=mock_agent
    )
    
    assert result is True
    mock_agent.generate_tags.assert_called_once_with(history)
    
    # ロードして確認
    loaded = session_manager.load_session(session_id)
    assert loaded["tags"] == ["AI", "検索", "技術"]


def test_load_session_with_tags(session_manager):
    """タグが正しくロード・パースされることを確認"""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    # 直接データベースにタグを保存
    with sqlite3.connect(session_manager.db_path) as conn:
        conn.execute(
            "UPDATE sessions SET tags = ? WHERE id = ?",
            (json.dumps(["Python", "AI", "機械学習"]), session_id)
        )
        conn.commit()
    
    # ロードして確認
    loaded = session_manager.load_session(session_id)
    assert loaded["tags"] == ["Python", "AI", "機械学習"]


def test_load_session_with_null_tags(session_manager):
    """tags列がNULLの場合、空リストとして扱われることを確認"""
    session_id = session_manager.create_session("Test", "gpt-oss:20b", "ja")
    
    # tagsはデフォルトでNULL
    loaded = session_manager.load_session(session_id)
    assert loaded["tags"] == []


def test_list_sessions_with_date_filter(session_manager):
    """date_from/date_toフィルタが正しく動作することを確認"""
    import time
    
    # 異なる日付のセッションを作成（created_atは実際にはCURRENT_TIMESTAMPなので、手動で設定）
    session1_id = session_manager.create_session("Session 1", "gpt-oss:20b", "ja")
    
    # 日付を変更（直接データベース操作）
    with sqlite3.connect(session_manager.db_path) as conn:
        conn.execute(
            "UPDATE sessions SET created_at = ? WHERE id = ?",
            ("2025-01-15 10:00:00", session1_id)
        )
        conn.commit()
    
    session2_id = session_manager.create_session("Session 2", "gpt-oss:20b", "ja")
    with sqlite3.connect(session_manager.db_path) as conn:
        conn.execute(
            "UPDATE sessions SET created_at = ? WHERE id = ?",
            ("2025-02-20 15:00:00", session2_id)
        )
        conn.commit()
    
    # 日付範囲でフィルタ
    sessions = session_manager.list_sessions(date_from="2025-02-01", date_to="2025-02-28")
    
    assert len(sessions) == 1
    assert sessions[0]["id"] == session2_id


def test_list_sessions_with_tag_filter(session_manager):
    """tagsフィルタが正しく動作することを確認（複数タグのANDロジック）"""
    session1_id = session_manager.create_session("Session 1", "gpt-oss:20b", "ja")
    session2_id = session_manager.create_session("Session 2", "gpt-oss:20b", "ja")
    session3_id = session_manager.create_session("Session 3", "gpt-oss:20b", "ja")
    
    # タグを直接設定
    with sqlite3.connect(session_manager.db_path) as conn:
        conn.execute("UPDATE sessions SET tags = ? WHERE id = ?", 
                    (json.dumps(["AI", "Python"]), session1_id))
        conn.execute("UPDATE sessions SET tags = ? WHERE id = ?", 
                    (json.dumps(["AI", "機械学習"]), session2_id))
        conn.execute("UPDATE sessions SET tags = ? WHERE id = ?", 
                    (json.dumps(["Python", "機械学習"]), session3_id))
        conn.commit()
    
    # 単一タグでフィルタ
    sessions = session_manager.list_sessions(tags=["AI"])
    assert len(sessions) == 2
    assert set(s["id"] for s in sessions) == {session1_id, session2_id}
    
    # 複数タグでフィルタ（ANDロジック）
    sessions = session_manager.list_sessions(tags=["AI", "Python"])
    assert len(sessions) == 1
    assert sessions[0]["id"] == session1_id


def test_search_sessions_with_tags(session_manager):
    """タグ検索が正しく動作することを確認"""
    session1_id = session_manager.create_session("Session 1", "gpt-oss:20b", "ja")
    session2_id = session_manager.create_session("Session 2", "gpt-oss:20b", "ja")
    
    # タグを設定
    with sqlite3.connect(session_manager.db_path) as conn:
        conn.execute("UPDATE sessions SET tags = ? WHERE id = ?", 
                    (json.dumps(["Python", "AI"]), session1_id))
        conn.execute("UPDATE sessions SET tags = ? WHERE id = ?", 
                    (json.dumps(["Java", "Backend"]), session2_id))
        conn.commit()
    
    # タグで検索
    results = session_manager.search_sessions("Python")
    
    assert len(results) == 1
    assert results[0]["id"] == session1_id
    assert "Python" in json.loads(results[0]["tags"])


# ============================================================================
# スキーマバージョン管理テスト
# ============================================================================

def test_schema_version_table_creation(temp_db_path):
    """schema_versionテーブルが正しく作成されるか"""
    # マイグレーションスクリプトを直接実行
    import sys
    from pathlib import Path
    
    # プロジェクトルートのmigrate_db.pyをインポート
    project_root = Path(__file__).parent.parent
    sys.path.insert(0, str(project_root))
    
    from migrate_db import ensure_schema_version_table
    
    # schema_versionテーブルを作成
    with sqlite3.connect(temp_db_path) as conn:
        ensure_schema_version_table(conn)
        
        # テーブルが存在するか確認
        cursor = conn.execute(
            "SELECT name FROM sqlite_master WHERE type='table' AND name='schema_version'"
        )
        assert cursor.fetchone() is not None
        
        # カラムを確認
        cursor = conn.execute("PRAGMA table_info(schema_version)")
        columns = {row[1] for row in cursor.fetchall()}
        assert columns == {"version", "applied_at", "description"}


def test_initial_schema_version(temp_db_path):
    """新規データベースがバージョン1として初期化されるか"""
    import sys
    from pathlib import Path
    
    project_root = Path(__file__).parent.parent
    sys.path.insert(0, str(project_root))
    
    from migrate_db import run_migrations, get_current_schema_version
    
    # マイグレーション実行
    success = run_migrations(temp_db_path)
    assert success is True
    
    # バージョンを確認
    with sqlite3.connect(temp_db_path) as conn:
        version = get_current_schema_version(conn)
        assert version == 1


def test_migration_idempotency(temp_db_path):
    """同じマイグレーションを複数回実行しても安全か"""
    import sys
    from pathlib import Path
    
    project_root = Path(__file__).parent.parent
    sys.path.insert(0, str(project_root))
    
    from migrate_db import run_migrations, get_current_schema_version
    
    # 1回目のマイグレーション
    success1 = run_migrations(temp_db_path)
    assert success1 is True
    
    # データを追加
    manager = SessionManager(db_path=temp_db_path)
    session_id = manager.create_session("Test Session", "gpt-oss:20b", "ja")
    
    # 2回目のマイグレーション
    success2 = run_migrations(temp_db_path)
    assert success2 is True
    
    # データが保持されているか確認
    loaded = manager.load_session(session_id)
    assert loaded is not None
    assert loaded["name"] == "Test Session"
    
    # バージョンが変わっていないか確認
    with sqlite3.connect(temp_db_path) as conn:
        version = get_current_schema_version(conn)
        assert version == 1


def test_schema_version_tracking(temp_db_path):
    """マイグレーション実行後にバージョンが正しく記録されるか"""
    import sys
    from pathlib import Path
    
    project_root = Path(__file__).parent.parent
    sys.path.insert(0, str(project_root))
    
    from migrate_db import run_migrations
    
    # マイグレーション実行
    run_migrations(temp_db_path)
    
    # schema_versionテーブルを確認
    with sqlite3.connect(temp_db_path) as conn:
        cursor = conn.execute(
            "SELECT version, description FROM schema_version ORDER BY version"
        )
        rows = cursor.fetchall()
        
        # バージョン1が記録されているか
        assert len(rows) >= 1
        assert rows[0][0] == 1
        assert "Initial schema" in rows[0][1]


def test_backup_creation(temp_db_path):
    """バックアップが正しく作成されるか"""
    import sys
    from pathlib import Path
    
    project_root = Path(__file__).parent.parent
    sys.path.insert(0, str(project_root))
    
    from migrate_db import create_backup
    
    # 既存のデータベースを作成
    manager = SessionManager(db_path=temp_db_path)
    manager.create_session("Test", "gpt-oss:20b", "ja")
    
    # バックアップ作成
    backup_path = create_backup(temp_db_path, 0)
    
    assert backup_path is not None
    assert backup_path.exists()
    assert "backup_v0" in backup_path.name
    
    # バックアップが実際のコピーであることを確認
    original_size = temp_db_path.stat().st_size
    backup_size = backup_path.stat().st_size
    assert original_size == backup_size


def test_migration_rollback_on_error(temp_db_path):
    """マイグレーション中のエラー時にロールバックされるか"""
    import sys
    from pathlib import Path
    
    project_root = Path(__file__).parent.parent
    sys.path.insert(0, str(project_root))
    
    from migrate_db import ensure_schema_version_table, set_schema_version
    
    # 部分的な初期化
    with sqlite3.connect(temp_db_path) as conn:
        ensure_schema_version_table(conn)
        
        # 不正なバージョンを記録しようとする（説明なし）
        try:
            conn.execute("INSERT INTO schema_version (version) VALUES (?)", (99,))
            conn.commit()
            assert False, "Should have raised an error"
        except sqlite3.IntegrityError:
            # descriptionカラムがNOT NULLなのでエラーが発生するはず
            pass


