    """Test that default group is created on SessionManager initialization."""
    manager = SessionManager(db_path=temp_db_path)
    
    # Verify default group exists
    default_group = manager.get_group(1)
    assert default_group is not None
    assert default_group["id"] == 1


def test_sessions_without_group_id_assigned_to_default(session_manager):
